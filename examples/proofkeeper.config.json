{
  "environments": {
    "development": { "url": "http://localhost:3000" },
    "production": { "url": "https://shop.example.com", "restrictions": ["read-only", "never create data"] }
  },
  "defaultTarget": "development",
  "auth": { "method": "email-password", "provider": "WorkOS" },
  "personas": [
    { "name": "shopper", "testFocus": ["cart", "checkout"] },
    { "name": "guest", "testFocus": ["browse"], "cannotDo": ["checkout", "save-payment"] }
  ],
  "capabilities": [
    {
      "id": "REQ-DEMO-CHECKOUT",
      "paths": ["src/checkout/**", "src/payment/**", "api/checkout/**"],
      "environment": "development",
      "persona": "shopper",
      "goal": "Complete a checkout with valid payment and confirm the order number shows.",
      "artifact": "examples/demo-corpus/rac/requirements/demo-checkout.md"
    },
    {
      "id": "REQ-DEMO-CART",
      "paths": ["src/cart/**"],
      "url": "http://localhost:3000/cart"
    }
  ]
}
